{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "设备测试",
      "type": "debugpy",
      "request": "launch",
      "program": "device_test.py",
      "cwd": "${workspaceFolder}",
      "python": "D:/anaconda/envs/rppg/python.exe",
      "console": "integratedTerminal"
    },     
    {
      "name": "进程清理",
      "type": "debugpy",
      "request": "launch",
      "program": "kill.py",
      "cwd": "${workspaceFolder}",
      "python": "D:/anaconda/envs/rppg/python.exe",
      "console": "integratedTerminal"
    },    
    {
      "name": "后端 (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "app.py",
      "cwd": "${workspaceFolder}/backend",
      "python": "D:/anaconda/envs/rppg/python.exe",
      "args": [
        "http://192.168.3.94:8080/video",
        "1"
      ],
      "env": {
        "CONDA_DEFAULT_ENV": "rppg",
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "前端 (Nuxt)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "restart": true,
      "autoAttachChildProcesses": true
    }
  ],
  "compounds": [
    {
      "name": "一键启动",
      "configurations": ["后端 (Flask)", "前端 (Nuxt)"]
    }
  ]
}