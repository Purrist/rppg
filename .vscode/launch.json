{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "后端 (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "app.py",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "http://192.168.3.94:8080/video",
        "1"
      ]
    },    
    {
      "name": "前端 (Nuxt)",
      "type": "pwa-node",           // 改为 pwa-node
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",  // 不自动打开控制台
      "restart": true,                         // 自动重启
      "autoAttachChildProcesses": true         // 附加子进程
    }
  ],
  "compounds": [
    {
      "name": "一键启动 (后端+前端)",
      "configurations": ["后端 (Flask)", "前端 (Nuxt)"]
    }
  ]
}
