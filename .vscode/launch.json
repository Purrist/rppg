{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "后端 (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "app.py",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "http://192.168.3.94:8080/video",
        "1"
      ]
    },    
    {
      "name": "一键转化",
      "type": "debugpy",
      "request": "launch",
      "program": "convert.py",
      "cwd": "${workspaceFolder}/"
    },
    {
      "name": "前端 (Nuxt)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal"
    },
  ],
  "compounds": [
    {
      "name": "一键启动 (后端+前端)",
      "configurations": ["后端 (Flask)", "前端 (Nuxt)"]
    }
  ]
}
